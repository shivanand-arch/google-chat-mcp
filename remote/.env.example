# Google OAuth client (create at console.cloud.google.com)
# The authorized redirect URI must be: https://<your-railway-url>/oauth/google/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Public URL where this server is deployed (no trailing slash)
# e.g. https://google-chat-mcp-production.up.railway.app
PUBLIC_URL=https://example.up.railway.app

# Random 32+ char string used to sign our own auth codes / tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Optional — restrict connector to a specific Google Workspace domain
# (e.g. "exotel.com"). Leave blank to allow any Google account.
ALLOWED_HD=

# Port (Railway sets this automatically; default 8080 for local dev)
PORT=8080
